import easyocr

reader = easyocr.Reader(['de', 'en'], gpu=False)

def ocr_easyocr(image_path):

    result = reader.readtext(
        image_path,
        detail=1,
        paragraph=False,
        rotation_info=[90, 180, 270]
    )

    text = "\n".join([item[1] for item in result if len(item) >= 2])

    return image_path, text





def ocr_with_boxes_and_text_easyocr(image_path, scale=2.0, show_text=False, show_box=True, show_preview=True):
    import cv2
    import matplotlib.pyplot as plt

    proc = preprocess_for_easyocr(image_path, scale=scale)

    result = reader.readtext(
        proc,
        detail=1,
        paragraph=False,
        rotation_info=[90, 180, 270]
    )

    img_boxes = None
    text = ""

    if show_box:
        img_boxes = cv2.cvtColor(proc.copy(), cv2.COLOR_BGR2RGB)

        for item in result:
            bbox = item[0]   # [[x1,y1],[x2,y2],[x3,y3],[x4,y4]]
            pts = [(int(x), int(y)) for x, y in bbox]

            for i in range(4):
                pt1 = pts[i]
                pt2 = pts[(i + 1) % 4]
                cv2.line(img_boxes, pt1, pt2, (0, 255, 0), 2)

        plt.figure(figsize=(12, 16))
        plt.imshow(img_boxes)
        plt.title(f"Detected Text Boxes: {image_path}")
        plt.axis("off")
        plt.show()

    if show_text:
        text = "\n".join([item[1] for item in result if len(item) >= 2])

        if show_preview:
            print(text[:3000])
        else:
            print(text)

    return img_boxes, text





